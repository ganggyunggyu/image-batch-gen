GEMINI_API_KEY=your_api_key_here

# Z.AI (GLM-Image) - https://z.ai 에서 발급
ZAI_API_KEY=your_zai_api_key_here
ZAI_SIZE=1280x1280

# 공통
PROMPT_VERSION=v2
IMAGE_DELAY_MS=2000

# 카테고리 (food 또는 beauty)
CATEGORY_TYPE=food

# 워터마크 제거 (true/false)
REMOVE_WATERMARK=true

# Imagen 4 설정
IMAGEN_MODEL=imagen-4.0-generate-001
# 모델 옵션: imagen-4.0-fast-generate-001 ($0.02), imagen-4.0-generate-001 ($0.04), imagen-4.0-ultra-generate-001 ($0.06)
IMAGEN_ASPECT_RATIO=1:1
# 비율 옵션: 1:1, 3:4, 4:3, 9:16, 16:9
IMAGEN_SIZE=1K
# 크기 옵션: 1K, 2K (Ultra/Standard만 지원)
